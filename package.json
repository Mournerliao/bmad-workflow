{
  "name": "mourner-bmad-workflow",
  "version": "0.2.0",
  "description": "Official BMAD installer wrapper with Mourner customizations and Claude/Codex/Cursor adapters.",
  "license": "MIT",
  "bin": {
    "mourner-bmad-workflow": "installer/index.js"
  },
  "files": [
    "installer/",
    "customize/",
    "custom-content/",
    "adapters/",
    "plugins/",
    "README.md",
    "LICENSE*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mournerliao/bmad-workflow.git"
  },
  "homepage": "https://github.com/Mournerliao/bmad-workflow",
  "keywords": [
    "bmad",
    "workflow",
    "installer",
    "claude-code",
    "codex",
    "cursor"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "test -x node_modules/.bin/husky && node_modules/.bin/husky || true",
    "commitlint": "commitlint --edit",
    "commitlint:check": "commitlint --from HEAD~1 --to HEAD --verbose",
    "check:release": "node scripts/check-release.js",
    "pack:release": "node scripts/pack-release.js",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "install:claude": "node installer/index.js install --target claude --directory .",
    "install:codex": "node installer/index.js install --target codex --directory .",
    "install:cursor": "node installer/index.js install --target cursor --directory .",
    "install:all": "node installer/index.js install --target both --directory .",
    "generate:claude": "node installer/index.js generate --target claude --directory .",
    "generate:codex": "node installer/index.js generate --target codex --directory .",
    "generate:cursor": "node installer/index.js generate --target cursor --directory .",
    "verify:dry-run": "node installer/index.js verify --target both --directory . --dry-run"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7"
  }
}
